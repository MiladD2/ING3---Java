<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <HBox spacing="20.0">
         <children>
            <VBox spacing="10.0" HBox.hgrow="ALWAYS">
               <children>
                  <Label fx:id="detailsTitle" styleClass="label-title" text="Titre de l'élément" />
                  <Label fx:id="detailsSubtitle" style="-fx-font-size: 18px; -fx-text-fill: #b3b3b3;" text="Sous-titre (Artiste, Genre, etc.)" />
                  <HBox fx:id="detailsMetadata" spacing="20.0">
                     <children>
                        <Label fx:id="detailsLabel1" text="Info 1" />
                        <Label fx:id="detailsLabel2" text="Info 2" />
                     </children>
                  </HBox>
               </children>
            </VBox>
            <Button fx:id="detailsPlayButton" mnemonicParsing="false" styleClass="button-primary" text="Lire tout" visible="false" />
         </children>
      </HBox>
      <Separator />
      <VBox fx:id="detailsContentArea" spacing="10.0" VBox.vgrow="ALWAYS">
         <children>
            <Label fx:id="detailsContentTitle" style="-fx-font-weight: bold;" text="Contenu" />
            <ListView fx:id="detailsListView" VBox.vgrow="ALWAYS" />
         </children>
      </VBox>
      <Button mnemonicParsing="false" onAction="#showSearch" styleClass="button-secondary" text="Retour à la recherche" />
   </children>
   <padding>
      <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
   </padding>
</VBox>
