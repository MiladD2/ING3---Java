<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <Label styleClass="label-title" text="Tableau de bord Statistiques" />
      
      <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
         <content>
            <FlowPane hgap="25.0" vgap="25.0">
               <children>
                  <!-- Carte Utilisateurs -->
                  <VBox prefHeight="130.0" prefWidth="220.0" style="-fx-background-color: #181818; -fx-background-radius: 12; -fx-alignment: CENTER; -fx-spacing: 5; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.4), 10, 0, 0, 5);">
                     <children>
                        <Label style="-fx-text-fill: #b3b3b3; -fx-font-size: 14px; -fx-font-weight: bold;" text="UTILISATEURS" />
                        <Label fx:id="statUserCount" style="-fx-text-fill: #1db954; -fx-font-size: 36px; -fx-font-weight: bold;" text="0" />
                     </children>
                  </VBox>
                  
                  <!-- Carte Morceaux -->
                  <VBox prefHeight="130.0" prefWidth="220.0" style="-fx-background-color: #181818; -fx-background-radius: 12; -fx-alignment: CENTER; -fx-spacing: 5; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.4), 10, 0, 0, 5);">
                     <children>
                        <Label style="-fx-text-fill: #b3b3b3; -fx-font-size: 14px; -fx-font-weight: bold;" text="MORCEAUX" />
                        <Label fx:id="statSongCount" style="-fx-text-fill: #1db954; -fx-font-size: 36px; -fx-font-weight: bold;" text="0" />
                     </children>
                  </VBox>
                  
                  <!-- Carte Albums -->
                  <VBox prefHeight="130.0" prefWidth="220.0" style="-fx-background-color: #181818; -fx-background-radius: 12; -fx-alignment: CENTER; -fx-spacing: 5; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.4), 10, 0, 0, 5);">
                     <children>
                        <Label style="-fx-text-fill: #b3b3b3; -fx-font-size: 14px; -fx-font-weight: bold;" text="ALBUMS" />
                        <Label fx:id="statAlbumCount" style="-fx-text-fill: #1db954; -fx-font-size: 36px; -fx-font-weight: bold;" text="0" />
                     </children>
                  </VBox>
                  
                  <!-- Carte Groupes -->
                  <VBox prefHeight="130.0" prefWidth="220.0" style="-fx-background-color: #181818; -fx-background-radius: 12; -fx-alignment: CENTER; -fx-spacing: 5; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.4), 10, 0, 0, 5);">
                     <children>
                        <Label style="-fx-text-fill: #b3b3b3; -fx-font-size: 14px; -fx-font-weight: bold;" text="GROUPES" />
                        <Label fx:id="statGroupCount" style="-fx-text-fill: #1db954; -fx-font-size: 36px; -fx-font-weight: bold;" text="0" />
                     </children>
                  </VBox>
                  
                  <!-- Carte Écoutes Totales -->
                  <VBox prefHeight="150.0" prefWidth="465.0" style="-fx-background-color: #1db954; -fx-background-radius: 12; -fx-alignment: CENTER; -fx-spacing: 5; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.4), 10, 0, 0, 5);">
                     <children>
                        <Label style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="ÉCOUTES TOTALES" />
                        <Label fx:id="statTotalPlays" style="-fx-text-fill: white; -fx-font-size: 48px; -fx-font-weight: bold;" text="0" />
                        <Label style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12px;" text="Cumul de toutes les lectures sur JAVAZIK" />
                     </children>
                  </VBox>
               </children>
               <padding>
                  <Insets bottom="20.0" left="10.0" right="20.0" top="10.0" />
               </padding>
            </FlowPane>
         </content>
      </ScrollPane>
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>
