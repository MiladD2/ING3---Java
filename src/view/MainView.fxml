<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:id="mainPane" prefHeight="750.0" prefWidth="1100.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="view.ViewController">
   <left>
      <VBox prefWidth="240.0" styleClass="sidebar" BorderPane.alignment="CENTER">
         <children>
            <Label styleClass="label-title" text="JAVAZIK">
               <VBox.margin>
                  <Insets bottom="30.0" left="20.0" right="20.0" top="30.0" />
               </VBox.margin>
            </Label>
            
            <VBox spacing="5.0">
               <children>
                  <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#showHome" styleClass="nav-button" text="Accueil" />
                  <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#showSearch" styleClass="nav-button" text="Rechercher" />
               </children>
            </VBox>

            <Separator prefWidth="200.0">
               <VBox.margin>
                  <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
               </VBox.margin>
            </Separator>
            
            <VBox fx:id="abonneMenu" spacing="5.0">
               <children>
                  <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#showPlaylists" styleClass="nav-button" text="Mes Playlists" />
                  <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#showHistory" styleClass="nav-button" text="Historique" />
               </children>
            </VBox>
            
            <VBox fx:id="adminMenu" spacing="5.0">
               <children>
                  <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#showAdminDashboard" styleClass="nav-button" text="Gestion Catalogue" />
               </children>
            </VBox>
            
            <Region VBox.vgrow="ALWAYS" />
            
            <VBox fx:id="guestCounterBox" alignment="CENTER" spacing="8.0" visible="false" managed="false">
               <children>
                  <Label style="-fx-text-fill: #b3b3b3; -fx-font-size: 11px; -fx-font-weight: bold;" text="MODE VISITEUR" />
                  <Label fx:id="guestRemainingLabel" style="-fx-text-fill: white; -fx-background-color: #1db954; -fx-padding: 5 15; -fx-background-radius: 15; -fx-font-weight: bold;" text="5 écoutes restantes" />
               </children>
               <VBox.margin>
                  <Insets bottom="20.0" />
               </VBox.margin>
            </VBox>
            
            <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleLogout" styleClass="nav-button" text="Déconnexion" />
         </children>
         <padding>
            <Insets bottom="20.0" />
         </padding>
      </VBox>
   </left>
   
   <bottom>
      <HBox alignment="CENTER_LEFT" prefHeight="100.0" minHeight="100.0" spacing="20.0" styleClass="player-bar" BorderPane.alignment="CENTER">
         <children>
            <!-- Track Info -->
            <VBox alignment="CENTER_LEFT" prefWidth="250.0" minWidth="200.0">
               <children>
                  <Label fx:id="currentTrackTitle" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: white;" text="Aucun morceau" />
                  <Label fx:id="currentTrackArtist" style="-fx-text-fill: #b3b3b3; -fx-font-size: 12px;" text="-" />
               </children>
            </VBox>
            
            <!-- Player Controls & Progress -->
            <VBox alignment="CENTER" spacing="8.0" HBox.hgrow="ALWAYS">
               <children>
                  <HBox alignment="CENTER" spacing="10.0">
                     <children>
                        <Button mnemonicParsing="false" onAction="#handlePrevious" styleClass="nav-button" text="⏮" />
                        <Button fx:id="mainPlayButton" mnemonicParsing="false" onAction="#handlePlayPause" styleClass="button-primary" text="▶" />
                        <Button mnemonicParsing="false" onAction="#handleNext" styleClass="nav-button" text="⏭" />
                     </children>
                  </HBox>

                  <HBox alignment="CENTER" spacing="10.0">
                     <children>
                        <Label fx:id="currentTimeLabel" style="-fx-font-size: 11px; -fx-text-fill: #b3b3b3; -fx-min-width: 35;" text="0:00" alignment="CENTER_RIGHT" />
                        <Slider fx:id="trackProgressSlider" maxWidth="600.0" HBox.hgrow="ALWAYS" />
                        <Label fx:id="totalTimeLabel" style="-fx-font-size: 11px; -fx-text-fill: #b3b3b3; -fx-min-width: 35;" text="0:00" />
                     </children>
                  </HBox>
               </children>
            </VBox>
            
            <!-- Volume -->
            <HBox alignment="CENTER_RIGHT" prefWidth="250.0" minWidth="150.0" spacing="10.0">
               <children>
                  <Label text="🔈" style="-fx-text-fill: #b3b3b3;" />
                  <Slider fx:id="volumeSlider" prefWidth="120.0" value="50.0" />
               </children>
            </HBox>
         </children>
         <padding>
            <Insets left="20.0" right="20.0" />
         </padding>
      </HBox>
   </bottom>
   
   <center>
      <ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" BorderPane.alignment="CENTER">
         <content>
            <StackPane fx:id="contentArea">
               <padding>
                  <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
               </padding>
            </StackPane>
         </content>
      </ScrollPane>
   </center>
</BorderPane>
