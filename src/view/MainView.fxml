<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<BorderPane fx:id="mainPane" prefHeight="720.0" prefWidth="1080.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="view.ViewController">
   <left>
      <VBox prefWidth="240.0" styleClass="sidebar" BorderPane.alignment="CENTER">
         <children>
            <Label styleClass="label-title" text="JAVAZIK">
               <VBox.margin>
                  <Insets bottom="30.0" left="20.0" right="20.0" top="30.0" />
               </VBox.margin>
            </Label>
            <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#showHome" styleClass="nav-button" text="Accueil" />
            <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#showSearch" styleClass="nav-button" text="Rechercher" />
            <Separator prefWidth="200.0">
               <VBox.margin>
                  <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
               </VBox.margin>
            </Separator>
            <VBox fx:id="abonneMenu" spacing="10.0">
               <children>
                  <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#showPlaylists" styleClass="nav-button" text="Mes Playlists" />
                  <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#showHistory" styleClass="nav-button" text="Historique" />
               </children>
            </VBox>
            <VBox fx:id="adminMenu" spacing="10.0">
               <children>
                  <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#showAdminDashboard" styleClass="nav-button" text="Gestion Catalogue" />
               </children>
            </VBox>
            <Region VBox.vgrow="ALWAYS" />
            <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleLogout" styleClass="nav-button" text="Déconnexion" />
         </children>
      </VBox>
   </left>
   <bottom>
      <HBox alignment="CENTER_LEFT" prefHeight="90.0" spacing="20.0" styleClass="player-bar" BorderPane.alignment="CENTER">
         <children>
            <VBox alignment="CENTER_LEFT" prefWidth="200.0">
               <children>
                  <Label fx:id="currentTrackTitle" style="-fx-font-weight: bold;" text="Aucun morceau" />
                  <Label fx:id="currentTrackArtist" style="-fx-text-fill: #b3b3b3;" text="-" />
               </children>
            </VBox>
            <HBox alignment="CENTER" spacing="15.0" HBox.hgrow="ALWAYS">
               <children>
                  <VBox alignment="CENTER" spacing="5.0" HBox.hgrow="ALWAYS">
                     <children>
                        <HBox alignment="CENTER" spacing="10.0">
                           <children>
                              <Button mnemonicParsing="false" styleClass="nav-button" text="⏮" />
                              <Button fx:id="mainPlayButton" mnemonicParsing="false" onAction="#handlePlayPause" styleClass="button-primary" text="▶" />
                              <Button mnemonicParsing="false" styleClass="nav-button" text="⏭" />
                           </children>
                        </HBox>
                        <HBox alignment="CENTER" spacing="10.0">
                           <children>
                              <Label fx:id="currentTimeLabel" style="-fx-font-size: 11px; -fx-text-fill: #b3b3b3;" text="0:00" />
                              <Slider fx:id="trackProgressSlider" HBox.hgrow="ALWAYS" />
                              <Label fx:id="totalTimeLabel" style="-fx-font-size: 11px; -fx-text-fill: #b3b3b3;" text="0:00" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </children>
            </HBox>
            <Slider fx:id="volumeSlider" prefWidth="150.0" value="50.0" />
         </children>
         <padding>
            <Insets left="20.0" right="20.0" />
         </padding>
      </HBox>
   </bottom>
   <center>
      <StackPane fx:id="contentArea" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
      </StackPane>
   </center>
</BorderPane>
