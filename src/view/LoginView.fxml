<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="20.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="view.ViewController">
   <children>
      <Label styleClass="label-title" text="Connexion à JAVAZIK" />
      <GridPane hgap="10.0" maxWidth="400.0" vgap="15.0">
        <columnConstraints>
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="250.0" />
        </columnConstraints>
        <rowConstraints>
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
        </rowConstraints>
         <children>
            <Label text="Identifiant :" />
            <TextField fx:id="loginField" GridPane.columnIndex="1" />
            <Label text="Mot de passe :" GridPane.rowIndex="1" />
            <PasswordField fx:id="passwordField" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            <Label text="Type :" GridPane.rowIndex="2" />
            <ComboBox fx:id="roleComboBox" prefWidth="250.0" GridPane.columnIndex="1" GridPane.rowIndex="2" />
         </children>
      </GridPane>
      <HBox alignment="CENTER" spacing="20.0">
         <children>
            <Button mnemonicParsing="false" onAction="#handleLogin" styleClass="button-primary" text="Se connecter" />
            <Button mnemonicParsing="false" onAction="#handleRegister" styleClass="button-secondary" text="Créer un compte" />
         </children>
      </HBox>
      <Separator maxWidth="400.0" />
      <Button mnemonicParsing="false" onAction="#handleVisitor" styleClass="button-secondary" text="Continuer en tant que visiteur" />
   </children>
   <padding>
      <Insets bottom="50.0" left="50.0" right="50.0" top="50.0" />
   </padding>
</VBox>
