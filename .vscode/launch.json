{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "java",
            "name": "JAVAZIK (Mac)",
            "request": "launch",
            "mainClass": "Main",
            "vmArgs": "--module-path \"${workspaceFolder}/lib/mac\" --add-modules javafx.controls,javafx.fxml,javafx.media -Djava.library.path=\"${workspaceFolder}/lib/mac\""
        },
        {
            "type": "java",
            "name": "JAVAZIK (Windows)",
            "request": "launch",
            "mainClass": "Main",
            "vmArgs": "--module-path \"${workspaceFolder}/lib/win\" --add-modules javafx.controls,javafx.fxml,javafx.media -Djava.library.path=\"${workspaceFolder}/lib/win\" -Dprism.order=d3d,sw"
        }
    ]
}
